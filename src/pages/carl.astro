---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/ui/Hero.astro';
import Accordion from '../components/ui/Accordion.astro';
import type { AccordionItem } from '../components/ui/Accordion.astro';
import { marked } from 'marked';
import data from '../content/settings/carl.json';

const accordionItems: AccordionItem[] = data.accordionItems.map(item => ({
  ...item,
  content: marked.parse(item.content) as string,
}));
---
<BaseLayout
  title="Carl Willandt — perhe, arvot ja tausta"
  description="Tutustu Carl Willandtiin — perheenisä, filosofian maisteri, viestintäpäällikkö ja Hämeenkyrön kunnanvaltuutettu. Kokoomuksen eduskuntavaaliehdokas Pirkanmaalta 2027."
>
  <Hero
    titleBold={data.heroTitleBold}
    imageSrc="/hero-carl.webp"
    imageAlt="Carl Willandt"
    short={true}
  />

  <section style="padding: 3rem 0 4rem; background-color: var(--color-cream);">
    <div class="container-custom">
      <div style="max-width: 56rem; margin: 0 auto;">
      <p style="font-size: 1.3125rem; font-weight: 400; color: var(--color-navy); line-height: 1.75; margin-bottom: 2.5rem;">
        {data.introParagraph}
      </p>

      <Accordion items={accordionItems} sectionTitle={data.sectionTitle} />
      </div>
    </div>
  </section>
</BaseLayout>
