---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ui/ContactForm.astro';
import data from '../content/settings/vapaaehtoiseksi.json';

const fields = [
  { name: 'name', label: 'Nimi', type: 'text' as const, required: true, placeholder: 'Etunimi Sukunimi' },
  { name: 'email', label: 'Sähköposti', type: 'email' as const, required: true, placeholder: 'sinä@esimerkki.fi' },
  { name: 'phone', label: 'Puhelinnumero', type: 'tel' as const, required: false, placeholder: '+358 40 123 4567' },
  { name: 'message', label: 'Osaaminen ja kiinnostuksen kohteet', type: 'textarea' as const, required: false, placeholder: 'Kerro lyhyesti, miten haluaisit osallistua kampanjaan...' },
];
---
<BaseLayout
  title="Vapaaehtoiseksi"
  description="Liity Carl Willandtin tukijoukkoihin — tule mukaan kampanjaan vapaaehtoisena kevään 2027 eduskuntavaaleissa."
>
  <section style="background-color: var(--color-navy); padding: 4rem 0;">
    <div class="container-custom">
      <h1 style="font-size: clamp(3rem, 8vw, 5rem); font-weight: 700; color: var(--color-cream); text-transform: uppercase; line-height: 1;">
        TUKIJOUKKOIHIN
      </h1>
    </div>
  </section>

  <section style="padding: 3rem 0; background-color: var(--color-cream);">
    <div class="container-custom">
      <div class="volunteer-grid">
        <div>
          <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem; color: var(--color-navy);">{data.introTitle}</h2>
          <p style="color: var(--color-body-text); line-height: 1.75; margin-bottom: 1rem;">
            {data.introParagraph1}
          </p>
          <p style="color: var(--color-body-text); line-height: 1.75;">
            {data.introParagraph2}
          </p>
        </div>
        <div>
          <ContactForm
            formName="vapaaehtoiseksi"
            fields={fields}
            submitLabel="Ilmoittaudu mukaan"
            successMessage="Kiitos ilmoittautumisesta! Otan sinuun pian yhteyttä sopivasta tavasta osallistua."
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .volunteer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
    max-width: 64rem;
  }
  @media (min-width: 768px) {
    .volunteer-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
