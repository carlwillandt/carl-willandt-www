---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blogi');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString('fi-FI', {
  day: 'numeric',
  month: 'numeric',
  year: 'numeric',
});
---
<BaseLayout title={post.data.title} description={post.data.excerpt} ogType="article">
  <script type="application/ld+json" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.data.title,
      "description": post.data.excerpt,
      "datePublished": post.data.date.toISOString(),
      "url": `https://willandt.fi/blogi/${post.id}`,
      "author": { "@id": "https://willandt.fi/#carl-willandt" },
      "publisher": { "@id": "https://willandt.fi/#carl-willandt" },
      "inLanguage": "fi",
      "image": "https://willandt.fi/og-image.jpg"
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Etusivu", "item": "https://willandt.fi" },
        { "@type": "ListItem", "position": 2, "name": "Blogi", "item": "https://willandt.fi/blogi" },
        { "@type": "ListItem", "position": 3, "name": post.data.title, "item": `https://willandt.fi/blogi/${post.id}` }
      ]
    }
  ])} />
  <!-- Page header: navy, integrates with sticky nav -->
  <section style="background-color: var(--color-navy); padding-bottom: 3.125rem;">
    <div class="container-custom" style="padding-top: 1.25rem; border-top: 1px solid rgba(253,252,251,0.15);">
      <!-- Back link with Lucide arrow-left -->
      <a
        href="/blogi"
        style="display: inline-flex; align-items: center; gap: 0.3125rem; color: var(--color-green-brand); font-weight: 600; font-size: 0.875rem; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; margin-bottom: 1rem;"
      >
        <!-- lucide/arrow-left -->
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
          <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
        </svg>
        Takaisin blogiin
      </a>

      <!-- BLOGI label -->
      <p style="font-weight: 800; font-size: clamp(2.5rem, 6vw, 4.75rem); color: var(--color-offwhite); text-transform: uppercase; line-height: 1; margin: 0 0 0;">
        BLOGI
      </p>
      <!-- Article title -->
      <p style="font-weight: 400; font-size: clamp(1.5rem, 4vw, 3.5rem); color: var(--color-offwhite); line-height: 1.1; margin: 0;">
        {post.data.title}
      </p>
    </div>
  </section>

  <!-- Article content -->
  <article style="padding: 3rem 0 4rem; background-color: var(--color-cream);">
    <div class="container-custom">
      <div style="max-width: 52.5rem; margin: 0 auto;">
        <!-- Category // date meta -->
        <div style="display: flex; align-items: center; gap: 1.25rem; color: #b8b2aa; font-size: 1rem; line-height: 1.75; padding-bottom: 0.3125rem; border-bottom: 1px solid rgba(13,27,42,0.15); margin-bottom: 2.5rem;">
          <span style="font-weight: 700;">{post.data.category}</span>
          <span style="font-weight: 500;">//</span>
          <time datetime={post.data.date.toISOString()} style="font-weight: 500;">{formattedDate}</time>
        </div>

        <div class="article-body">
          <Content />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-body {
    font-size: 1.3125rem;
    line-height: 1.75;
    color: var(--color-navy);
    font-weight: 400;
  }
  .article-body :global(p) { margin-bottom: 1.25rem; }
  .article-body :global(h2) { font-size: 1.625rem; font-weight: 700; margin: 2.5rem 0 1rem; color: var(--color-navy); }
  .article-body :global(h3) { font-size: 1.25rem; font-weight: 700; margin: 2rem 0 0.75rem; color: var(--color-navy); }
  .article-body :global(h4) { font-size: 1.0625rem; font-weight: 700; margin: 1.5rem 0 0.5rem; color: var(--color-navy); }
  .article-body :global(ul) { list-style-type: disc; margin-bottom: 1.5rem; padding-left: 1.5rem; }
  .article-body :global(ol) { list-style-type: decimal; margin-bottom: 1.5rem; padding-left: 1.5rem; }
  .article-body :global(li) { margin-bottom: 0.5rem; }
  .article-body :global(a) { color: var(--color-green-brand); text-decoration: underline; }
  .article-body :global(strong) { font-weight: 700; }
</style>
