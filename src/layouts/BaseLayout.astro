---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = 'Carl Willandt — Eduskuntavaaliehdokas 2027, Kokoomus, Pirkanmaa. Sivistystä, realismia ja rohkeutta.',
  ogImage = '/og-image.jpg',
  ogType = 'website',
} = Astro.props;

const siteUrl = 'https://willandt.fi';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
const pageTitle = title === 'Etusivu'
  ? 'Carl Willandt — Eduskuntavaaliehdokas 2027 · Kokoomus · Pirkanmaa'
  : title.includes('—') ? title : `${title} — Carl Willandt`;
---
<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400&display=swap" />

    <title>{pageTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Carl Willandt — Kokoomuksen eduskuntavaaliehdokas Pirkanmaalta 2027" />
    <meta property="og:locale" content="fi_FI" />
    <meta property="og:site_name" content="Carl Willandt" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@carlwillandt" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured Data: Person + WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": "https://willandt.fi/#carl-willandt",
        "name": "Carl Willandt",
        "url": "https://willandt.fi",
        "image": "https://willandt.fi/og-image.jpg",
        "jobTitle": "Eduskuntavaaliehdokas 2027",
        "description": "Kokoomuksen eduskuntavaaliehdokas Pirkanmaalta kevään 2027 vaaleissa. Filosofian maisteri, viestintäpäällikkö ja Hämeenkyrön kunnanvaltuutettu.",
        "memberOf": {
          "@type": "Organization",
          "name": "Kansallinen Kokoomus",
          "url": "https://www.kokoomus.fi"
        },
        "sameAs": [
          "https://www.facebook.com/p/Carl-Willandt-61570290832156/",
          "https://instagram.com/carl.willandt",
          "https://x.com/carlwillandt"
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": "https://willandt.fi/#website",
        "url": "https://willandt.fi",
        "name": "Carl Willandt",
        "description": "Carl Willandt — Eduskuntavaaliehdokas 2027, Kokoomus, Pirkanmaa.",
        "inLanguage": "fi",
        "publisher": {
          "@id": "https://willandt.fi/#carl-willandt"
        }
      }
    ])} />
  </head>
  <body>
    <Header />
    <!-- Spacer compensates for fixed header on non-hero pages -->
    <div class="header-space" aria-hidden="true"></div>
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
