---
interface Props {
  title: string;
  excerpt: string;
  date: Date;
  category: string;
  slug: string;
}

const { title, excerpt, date, category, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('fi-FI', {
  day: 'numeric',
  month: 'numeric',
  year: 'numeric',
});
---
<article class="blog-card">
  <div style="padding: 1.5rem; display: flex; flex-direction: column; flex: 1;">
    <p style="font-size: 0.75rem; font-weight: 600; color: #b8b2aa; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.75rem;">
      {category} // {formattedDate}
    </p>
    <h3 style="font-size: 1.0625rem; font-weight: 700; color: var(--color-navy); margin-bottom: 0.75rem; line-height: 1.35; flex: 1;">{title}</h3>
    <p style="color: var(--color-body-text); font-size: 0.875rem; line-height: 1.6; margin-bottom: 1.5rem;">{excerpt}</p>
    <a href={`/blogi/${slug}`} class="btn-primary" style="align-self: flex-start;">
      Lue lisää →
    </a>
  </div>
</article>
