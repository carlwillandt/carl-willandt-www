---
interface Props {
  title: string;
  excerpt: string;
  date: Date;
  category: string;
  slug: string;
}

const { title, excerpt, date, category, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('fi-FI', {
  day: 'numeric',
  month: 'numeric',
  year: 'numeric',
});
---
<article style="background: white; border: 1px solid #e5e7eb; border-radius: 0.5rem; overflow: hidden; display: flex; flex-direction: column; height: 100%; transition: box-shadow 0.2s;"
         onmouseover="this.style.boxShadow='0 4px 6px -1px rgba(0,0,0,0.1)'"
         onmouseout="this.style.boxShadow='none'">
  <div style="padding: 1.5rem; display: flex; flex-direction: column; flex: 1;">
    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; flex-wrap: wrap;">
      <span style="background: rgba(58,122,79,0.1); color: var(--color-green-brand); font-weight: 600; padding: 0.25rem 0.5rem; border-radius: 0.25rem; font-size: 0.75rem;">
        {category}
      </span>
      <time datetime={date.toISOString()} style="font-size: 0.75rem; color: #6b7280;">{formattedDate}</time>
    </div>
    <h3 style="font-size: 1rem; font-weight: 700; color: #111827; margin-bottom: 0.5rem; line-height: 1.4;">{title}</h3>
    <p style="color: #4b5563; font-size: 0.875rem; line-height: 1.6; margin-bottom: 1.25rem; flex: 1;">{excerpt}</p>
    <a
      href={`/blogi/${slug}`}
      style="display: inline-flex; align-items: center; color: var(--color-green-brand); font-weight: 700; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.05em; text-decoration: none;"
    >
      Lue lisää
      <svg style="width: 1rem; height: 1rem; margin-left: 0.25rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
