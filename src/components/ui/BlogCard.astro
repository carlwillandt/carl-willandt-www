---
interface Props {
  title: string;
  excerpt: string;
  date: Date;
  category: string;
  slug: string;
}

const { title, excerpt, date, category, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('fi-FI', {
  day: 'numeric',
  month: 'numeric',
  year: 'numeric',
});
---
<article class="blog-card">
  <div style="padding: 2.5rem 1.875rem 1.875rem; display: flex; flex-direction: column; flex: 1; gap: 0.3125rem;">
    <!-- Category // date -->
    <div style="display: flex; align-items: center; gap: 1.25rem; color: #b8b2aa; font-size: 1rem; line-height: 1; margin-bottom: 0.3125rem;">
      <span style="font-weight: 700;">{category}</span>
      <span style="font-weight: 500;">//</span>
      <span style="font-weight: 500;">
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </span>
    </div>
    <!-- Title -->
    <h3 style="font-weight: 500; font-size: 1.625rem; color: var(--color-navy); line-height: 1.5; margin: 0 0 0.3125rem;">{title}</h3>
    <!-- Excerpt -->
    <p style="font-weight: 500; font-size: 1.125rem; color: var(--color-body-text); line-height: 1.5; margin: 0 0 1.25rem; flex: 1;">{excerpt}</p>
    <!-- CTA -->
    <div>
      <a href={`/blogi/${slug}`} class="btn-primary">Lue lisää</a>
    </div>
  </div>
</article>
