---
interface Props {
  videoUrl?: string;
  bodyHtml: string;
}
const { videoUrl, bodyHtml } = Astro.props;
---
<section style="padding: 4rem 0; background-color: var(--color-cream);">
  <div class="container-custom video-grid">
    <div style="aspect-ratio: 16/9; background: rgba(13,27,42,0.08); border-radius: 0.75rem; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.1); position: relative;">
      {videoUrl ? (
        <iframe
          src={videoUrl}
          title="Carl Willandt video"
          style="width: 100%; height: 100%; border: none;"
          allowfullscreen
          loading="lazy"
        />
      ) : (
        <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: rgba(13,27,42,0.06);">
          <div style="width: 5rem; height: 5rem; background: var(--color-green-brand); border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
            <svg style="width: 2.5rem; height: 2.5rem; color: white; margin-left: 0.3rem;" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
        </div>
      )}
    </div>
    <div class="video-text" set:html={bodyHtml} />
  </div>
</section>

<style>
  .video-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  .video-text {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-body-text);
  }
  .video-text p { margin-bottom: 1rem; }
  .video-text p:last-child { margin-bottom: 0; }
  @media (min-width: 768px) {
    .video-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
