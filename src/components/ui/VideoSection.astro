---
interface Props {
  videoUrl?: string;
  bodyHtml: string;
  ctaLabel?: string;
  ctaHref?: string;
}
const { videoUrl, bodyHtml, ctaLabel, ctaHref } = Astro.props;
---
<section style="padding: 4rem 0; background-color: var(--color-cream);">
  <div class="container-custom video-grid">
    <div style="aspect-ratio: 16/9; background: rgba(13,27,42,0.08); border-radius: 0.75rem; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.1); position: relative;">
      {videoUrl ? (
        <iframe
          src={videoUrl}
          title="Carl Willandt video"
          style="width: 100%; height: 100%; border: none;"
          allowfullscreen
          loading="lazy"
        />
      ) : (
        <img
          src="/hero-tavoitteeni.webp"
          alt="Carl Willandt"
          style="width: 100%; height: 100%; object-fit: cover; object-position: 50% 30%;"
          loading="lazy"
        />
      )}
    </div>
    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
      <div class="video-text" set:html={bodyHtml} />
      {ctaLabel && ctaHref && (
        <div>
          <a href={ctaHref} class="btn-primary">{ctaLabel}</a>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .video-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  .video-text {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-body-text);
  }
  .video-text p { margin-bottom: 1rem; }
  .video-text p:last-child { margin-bottom: 0; }
  @media (min-width: 768px) {
    .video-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
