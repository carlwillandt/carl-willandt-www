---
export interface AccordionItem {
  id: string;
  title: string;
  icon?: string;  // lucide icon name
  content: string;
}

interface Props {
  items: AccordionItem[];
  sectionTitle?: string;
}

const ICONS: Record<string, string> = {
  'home': '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  'book-open': '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  'trophy': '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/>',
  'tree-pine': '<path d="m17 14 3 3.1a1 1 0 0 1-.7 1.7H4.7a1 1 0 0 1-.7-1.7L7 14h-.3a1 1 0 0 1-.7-1.7L9 9h-.2A1 1 0 0 1 8 7.3L12 3l4 4.3A1 1 0 0 1 15.2 9H15l3 3.3a1 1 0 0 1-.7 1.7H17z"/><path d="M12 22v-3"/>',
  'shield': '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
  'graduation-cap': '<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>',
  'scale': '<path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1z"/><path d="M7 21H17"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/>',
};

const { items, sectionTitle } = Astro.props;
const groupId = `acc-${Math.random().toString(36).slice(2, 7)}`;
---
<div>
  {sectionTitle && (
    <h2 style="font-size: 1.625rem; font-weight: 400; color: var(--color-navy); line-height: 1.75; margin-bottom: 1.5rem;">{sectionTitle}</h2>
  )}
  <div data-accordion-group={groupId}>
    {items.map((item, i) => (
      <div
        class="accordion-item"
        style={`border-left: 3px solid transparent; border-top: 1px solid rgba(13,27,42,0.1);${i === items.length - 1 ? ' border-bottom: 1px solid rgba(13,27,42,0.1);' : ''}`}
      >
        <button
          style="width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.25rem 1.875rem; text-align: left; background: transparent; cursor: pointer; border: none;"
          aria-expanded="false"
          aria-controls={`${groupId}-panel-${i}`}
          id={`${groupId}-btn-${i}`}
          data-accordion-trigger
        >
          <span style="display: flex; align-items: center; gap: 0.875rem; font-weight: 600; color: var(--color-navy); font-size: 1.3125rem; line-height: 1.3;">
            {item.icon && ICONS[item.icon] && (
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true" style="flex-shrink: 0; color: var(--color-green-brand);" set:html={ICONS[item.icon]} />
            )}
            {item.title}
          </span>
          <svg class="accordion-chevron" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true" style="color: var(--color-body-text); transition: transform 0.2s; flex-shrink: 0;">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </button>
        <div
          id={`${groupId}-panel-${i}`}
          role="region"
          aria-labelledby={`${groupId}-btn-${i}`}
          class="accordion-panel"
          style="display: none; padding: 0 1.875rem 1.875rem 1.875rem; color: var(--color-body-text); font-size: 1rem; line-height: 1.75;"
          set:html={item.content}
        />
      </div>
    ))}
  </div>
</div>

<style>
  .accordion-item:has(button[aria-expanded="true"]) {
    border-left-color: var(--color-green-brand) !important;
    background-color: var(--color-offwhite);
  }
  .accordion-chevron.rotated {
    transform: rotate(180deg);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-accordion-group]').forEach(group => {
    const triggers = Array.from(
      group.querySelectorAll<HTMLButtonElement>('[data-accordion-trigger]')
    );
    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const isAlreadyOpen = trigger.getAttribute('aria-expanded') === 'true';
        triggers.forEach(t => {
          t.setAttribute('aria-expanded', 'false');
          const panelId = t.getAttribute('aria-controls');
          if (panelId) {
            const panel = document.getElementById(panelId);
            if (panel) panel.style.display = 'none';
          }
          t.querySelector('.accordion-chevron')?.classList.remove('rotated');
        });
        if (!isAlreadyOpen) {
          trigger.setAttribute('aria-expanded', 'true');
          const panelId = trigger.getAttribute('aria-controls');
          if (panelId) {
            const panel = document.getElementById(panelId);
            if (panel) panel.style.display = 'block';
          }
          trigger.querySelector('.accordion-chevron')?.classList.add('rotated');
        }
      });
    });
  });
</script>
