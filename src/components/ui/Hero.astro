---
interface Props {
  title: string;
  subtitle?: string;
  bodyText?: string;
  imageSrc: string;
  imageAlt: string;
  ctaLabel?: string;
  ctaHref?: string;
  showKokoomusLogo?: boolean;
}

const {
  title,
  subtitle,
  bodyText,
  imageSrc,
  imageAlt,
  ctaLabel,
  ctaHref,
  showKokoomusLogo = false,
} = Astro.props;
---
<section style="position: relative; background-color: var(--color-navy); min-height: 65vh; display: flex; align-items: flex-end; overflow: hidden;">
  <!-- Background photo -->
  <div style="position: absolute; inset: 0;">
    <img
      src={imageSrc}
      alt={imageAlt}
      style="width: 100%; height: 100%; object-fit: cover; object-position: center;"
      loading="eager"
    />
    <div style="position: absolute; inset: 0; background: linear-gradient(to right, rgba(13,27,42,0.9) 0%, rgba(13,27,42,0.6) 50%, transparent 100%);"></div>
    <div style="position: absolute; inset: 0; background: rgba(13,27,42,0.3);"></div>
  </div>

  <!-- Content -->
  <div class="container-custom" style="position: relative; padding-top: 4rem; padding-bottom: 4rem; width: 100%;">
    <div style="max-width: 32rem;">
      {subtitle && (
        <p style="color: var(--color-green-brand); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.75rem;">
          {subtitle}
        </p>
      )}
      <h1 style="font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 700; color: var(--color-cream); line-height: 1; margin-bottom: 1rem; text-transform: uppercase;">
        {title}
      </h1>
      {bodyText && (
        <p style="color: rgba(245,243,240,0.8); font-size: 1rem; line-height: 1.6; margin-bottom: 2rem; max-width: 28rem;">
          {bodyText}
        </p>
      )}
      {ctaLabel && ctaHref && (
        <a href={ctaHref} class="btn-primary">{ctaLabel}</a>
      )}
    </div>

    {showKokoomusLogo && (
      <div class="kokoomus-logo-container" style="display: none; position: absolute; bottom: 2rem; right: 2rem;">
        <img src="/kokoomus-logo.png" alt="Kokoomus" style="height: 2rem; opacity: 0.7;" />
      </div>
    )}
  </div>
</section>

<style>
  @media (min-width: 768px) {
    section {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }
    .kokoomus-logo-container {
      display: block !important;
    }
  }
</style>
