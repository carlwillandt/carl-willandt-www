---
interface Props {
  titleBold?: string;
  titleRegular?: string;
  bodyText?: string;
  imageSrc: string;
  imageAlt: string;
  ctaLabel?: string;
  ctaHref?: string;
  showKokoomusLogo?: boolean;
  short?: boolean;
}

const {
  titleBold,
  titleRegular,
  bodyText,
  imageSrc,
  imageAlt,
  ctaLabel,
  ctaHref,
  showKokoomusLogo = false,
  short = false,
} = Astro.props;
---
<section class="hero-pulls-up" style={`position: relative; background-color: var(--color-navy); min-height: ${short ? 'calc(var(--header-h) + 20rem)' : '70vh'}; display: flex; align-items: flex-end; overflow: hidden;`}>
  <!-- Background photo -->
  <div style="position: absolute; inset: 0;">
    <img
      src={imageSrc}
      alt={imageAlt}
      style="width: 100%; height: 100%; object-fit: cover; object-position: center top;"
      loading="eager"
    />
    <div style="position: absolute; inset: 0; background-color: var(--color-navy); mix-blend-mode: color;"></div>
    <div style="position: absolute; inset: 0; background: linear-gradient(to right, var(--color-navy) 0%, rgba(13,27,42,0) 100%);"></div>
  </div>

  <!-- Content -->
  <div class="container-custom hero-content" style="position: relative; padding-top: calc(var(--header-h) + 2rem); padding-bottom: 5rem; width: 100%;">
    <div style="max-width: 40rem; display: flex; flex-direction: column; gap: 1.875rem;">
      {(titleBold || titleRegular) && (
        <div style="display: flex; flex-direction: column; line-height: 1; color: var(--color-offwhite);">
          {titleBold && (
            <p style="font-weight: 800; font-size: clamp(2.75rem, 7vw, 4.75rem); text-transform: uppercase; margin: 0;">{titleBold}</p>
          )}
          {titleRegular && (
            <p style="font-weight: 400; font-size: clamp(2rem, 5.25vw, 3.5rem); margin: 0;">{titleRegular}</p>
          )}
        </div>
      )}
      {bodyText && (
        <p style="color: var(--color-offwhite); font-weight: 300; font-size: clamp(1rem, 1.8vw, 1.3125rem); line-height: 1.5; margin: 0; max-width: 36rem;">
          {bodyText}
        </p>
      )}
      {ctaLabel && ctaHref && (
        <div>
          <a href={ctaHref} class="btn-primary">{ctaLabel}</a>
        </div>
      )}
    </div>

    {showKokoomusLogo && (
      <div class="kokoomus-logo-container" style="display: none; position: absolute; bottom: 5rem; right: 5.3125rem;">
        <img src="/kokoomus-logo.png" alt="Kokoomus" style="height: 1.625rem; opacity: 0.85;" />
      </div>
    )}
  </div>
</section>

<style>
  @media (min-width: 768px) {
    .hero-content {
      padding-top: calc(var(--header-h) + 2.5rem);
      padding-bottom: 5.3125rem;
    }
    .kokoomus-logo-container {
      display: block !important;
    }
  }
</style>
