---
interface Props {
  titleBold?: string;
  titleRegular?: string;
  bodyText?: string;
  imageSrc?: string;
  imageSrcs?: string[];
  imageAlt: string;
  imagePosition?: string;
  ctaLabel?: string;
  ctaHref?: string;
  showKokoomusLogo?: boolean;
  short?: boolean;
}

const {
  titleBold,
  titleRegular,
  bodyText,
  imageSrc,
  imageSrcs,
  imageAlt,
  imagePosition = '50% 50%',
  ctaLabel,
  ctaHref,
  showKokoomusLogo = false,
  short = false,
} = Astro.props;

const slides = imageSrcs && imageSrcs.length > 1 ? imageSrcs : (imageSrc ? [imageSrc] : []);
const isSlideshow = slides.length > 1;

// Crossfade timing: image 1 (top layer) fades out → image 2 (bottom layer, always visible) shows
const hold = 7;   // seconds fully visible
const fade = 2;   // crossfade duration
const total = (hold + fade) * slides.length;
const pHoldEnd  = +((hold / total) * 100).toFixed(3);
const pFadeEnd  = +(((hold + fade) / total) * 100).toFixed(3);
const pBackStart = +((( total - fade) / total) * 100).toFixed(3);
---

{isSlideshow && (
  <style set:html={`
    @keyframes heroFade {
      0%              { opacity: 1; }
      ${pHoldEnd}%    { opacity: 1; }
      ${pFadeEnd}%    { opacity: 0; }
      ${pBackStart}%  { opacity: 0; }
      100%            { opacity: 1; }
    }
  `} />
)}

<section class="hero-pulls-up" style={`position: relative; background-color: var(--color-navy); min-height: ${short ? 'calc(var(--header-h) + 20rem)' : '70vh'}; display: flex; align-items: flex-end; overflow: hidden;`}>
  <!-- Background photo(s) -->
  <div style="position: absolute; inset: 0;">
    {slides.map((src, i) => (
      <img
        src={src}
        alt={i === 0 ? imageAlt : ''}
        style={isSlideshow
          ? `position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: ${imagePosition}; z-index: ${slides.length - i};${i === 0 ? ` animation: heroFade ${total}s ease-in-out infinite;` : ' opacity: 1;'}`
          : `width: 100%; height: 100%; object-fit: cover; object-position: ${imagePosition};`}
        loading={i === 0 ? 'eager' : 'lazy'}
        aria-hidden={i > 0 ? 'true' : undefined}
      />
    ))}
    <!-- Gradient only — no colour overlay so images show naturally -->
    <div style="position: absolute; inset: 0; z-index: 10; background: linear-gradient(to right, rgba(13,27,42,0.75) 0%, rgba(13,27,42,0.2) 60%, rgba(13,27,42,0) 100%);"></div>
  </div>

  <!-- Content -->
  <div class="container-custom hero-content" style="position: relative; z-index: 20; padding-top: calc(var(--header-h) + 2rem); padding-bottom: 5rem; width: 100%;">
    <div style="max-width: 40rem; display: flex; flex-direction: column; gap: 1.875rem;">
      {(titleBold || titleRegular) && (
        <div style="display: flex; flex-direction: column; line-height: 1; color: var(--color-offwhite);">
          {titleBold && (
            <p style="font-weight: 800; font-size: clamp(2.75rem, 7vw, 4.75rem); text-transform: uppercase; margin: 0;">{titleBold}</p>
          )}
          {titleRegular && (
            <p style="font-weight: 400; font-size: clamp(2rem, 5.25vw, 3.5rem); margin: 0;">{titleRegular}</p>
          )}
        </div>
      )}
      {bodyText && (
        <p style="color: var(--color-offwhite); font-weight: 300; font-size: clamp(1rem, 1.8vw, 1.3125rem); line-height: 1.5; margin: 0; max-width: 36rem;">
          {bodyText}
        </p>
      )}
      {ctaLabel && ctaHref && (
        <div>
          <a href={ctaHref} class="btn-primary">{ctaLabel}</a>
        </div>
      )}
    </div>

    {showKokoomusLogo && (
      <div class="kokoomus-logo-container" style="display: none; position: absolute; bottom: 5rem; right: 5.3125rem; z-index: 20;">
        <img src="/kokoomus-logo.png" alt="Kokoomus" style="height: 1.625rem; opacity: 0.85;" />
      </div>
    )}
  </div>
</section>

<style>
  @media (min-width: 768px) {
    .hero-content {
      padding-top: calc(var(--header-h) + 2.5rem);
      padding-bottom: 5.3125rem;
    }
    .kokoomus-logo-container {
      display: block !important;
    }
  }
</style>
